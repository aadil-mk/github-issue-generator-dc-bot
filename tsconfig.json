{
  "compilerOptions": {
    /* Language & Environment */
    "target": "es2020",
    "module": "commonjs",

    /* Paths */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Interop */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    /* Type Checking */
    "strict": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
  },
}
